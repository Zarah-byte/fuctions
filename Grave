// RENDER STAMP GRID
let countBtns = document.querySelectorAll('.count-btn');
let punchItems = document.querySelectorAll('.punches li');

countBtns.forEach(function (btn) {
	btn.addEventListener('click', function () {
		countBtns.forEach(function (b) {
			b.classList.remove('selected');
		});

		btn.classList.add('selected');

		let count = Number(btn.dataset.count);

		punchItems.forEach(function (punch, index) {
			if (index < count) {
				punch.classList.remove('hidden');
			}

			if (index >= count) {
				punch.classList.add('hidden');
			}
		});
	});
});

// ICONS IN STAMP GRID
let icons = {
	smiley: '🙂',
	star: '★',
	heart: '♥',
	check: '✓'
};

let currentIcon = '★';

let iconBtns = document.querySelectorAll('.icon-btn');

iconBtns.forEach(function (btn) {
	btn.addEventListener('click', function () {
		iconBtns.forEach(function (b) {
			b.classList.remove('selected');
		});

		btn.classList.add('selected');
		currentIcon = icons[btn.dataset.icon];
		applyIconToGrid();
	});
});

function applyIconToGrid() {
	let punchItems = document.querySelectorAll('.punches li');

	punchItems.forEach(function (li) {
		let content = li.querySelector('.punch-content');

		if (content) {
			content.textContent = currentIcon;
		}

		if (!content) {
			li.textContent = currentIcon;
		}
	});
}

