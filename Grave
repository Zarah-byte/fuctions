======================== */
@media print {
	body * {
	visibility: hidden;
	}

	.card {
	border: #161616 .02rem solid;
	visibility: visible;
	position: absolute;
	top: 0;
	left: 0;
	width: 100%;
	}

	.card * {
	  visibility: visible;
	}

	/* '*' selectes alll children of the .card */

	header,
	footer,
	.column-1,
	.buttons {
	display: none;
	}
}

